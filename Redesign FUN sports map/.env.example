# Copy to .env and fill in your values.

# Supabase (Dashboard → Settings → API Keys)
# URL: https://<project-ref>.supabase.co  (ref = Project ID on Settings → General)
# Key: Legacy tab → "anon" "public" JWT (eyJ...). Do not use service_role here.
# If REST returns 401, the anon key is wrong, truncated, has spaces, or is from another project.
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc.W..

# Mapbox (from dashboard.mapbox.com → Access tokens; use a public token)
# Create a token and paste it here and in Vercel → Settings → Environment Variables.
VITE_MAPBOX_ACCESS_TOKEN=pk.eyJ1...
# Optional: custom Studio style (defaults to trcpoet dark style if omitted)
# VITE_MAPBOX_STYLE_URL=mapbox://styles/trcpoet/cmn1l2br1003e01s52y4q9uzt

# --- Server-only (Vercel / local /api/* dev proxy — never prefix with VITE_) ---
# Required for /api/venue-enrich (Wikidata hero images) in local dev:
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...  # Dashboard → Settings → API → service_role (secret!)
# SUPABASE_URL=https://xxxxx.supabase.co  # optional if VITE_SUPABASE_URL is already set
# OSM_IMPORT_SECRET=long-random-string   # Bearer token for POST /api/osm-venues-import
# WORLD_NEWS_API_KEY=...                 # server-only — Explore sports headlines (/api/local-news)
GOOGLE_PLACES_API_KEY=                   # server-only — venue photos (Places API New; enable billing in Google Cloud)
# MAPBOX_ACCESS_TOKEN=pk.eyJ1...         # optional server alias for /api/directions (falls back to VITE_MAPBOX_ACCESS_TOKEN)
